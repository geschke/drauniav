<Window x:Class="Drauniav.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="{DynamicResource AboutTitle}"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F3F5F7">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#D4D8DF" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,10,0">
                    <Image x:Name="AboutLogoImage" Stretch="Uniform" Visibility="Collapsed"/>
                    <iconPacks:PackIconMaterial x:Name="AboutHeaderIcon" Kind="InformationOutline" Width="18" Height="18" Foreground="#374151" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock Grid.Column="1" Text="{DynamicResource AboutHeader}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#D4D8DF" BorderThickness="1" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10" Text="{DynamicResource AboutDescription}" Foreground="#4B5563" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource AboutVersionLabel}" Margin="0,0,8,8" Foreground="#374151"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtVersionValue" Margin="0,0,0,8" Foreground="#111827"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource AboutAuthorLabel}" Margin="0,0,8,8" Foreground="#374151"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtAuthorValue" Margin="0,0,0,8" Foreground="#111827"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource AboutEmailLabel}" Margin="0,0,8,8" Foreground="#374151"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtEmailValue" Margin="0,0,0,8" Foreground="#111827"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource AboutGithubLabel}" Margin="0,0,8,8" Foreground="#374151"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" Foreground="#1D4ED8">
                    <Hyperlink x:Name="LnkGithub" RequestNavigate="LnkGithub_RequestNavigate">
                        <Run x:Name="TxtGithubValue"/>
                    </Hyperlink>
                </TextBlock>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource AboutLicenseLabel}" Margin="0,0,8,0" Foreground="#374151"/>
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtLicenseValue" Foreground="#111827"/>
            </Grid>
        </Border>

        <Button Grid.Row="2" Width="110" Height="34" HorizontalAlignment="Right" Margin="0,12,0,0" Click="BtnClose_Click">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="{DynamicResource AboutClose}"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
