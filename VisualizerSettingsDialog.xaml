<Window x:Class="AudioVisualizer.VisualizerSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="{DynamicResource VisualizerDialogTitle}"
        Width="640"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F3F5F7">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D4D8DF"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#F0F4FB"/>
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#E4ECFA"/>

        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C9D0DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C9D0DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#C9D0DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PrimaryButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PrimaryButtonBorder" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="PrimaryButtonBorder" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PrimaryButtonBorder" Property="Background" Value="#1E40AF"/>
                                <Setter TargetName="PrimaryButtonBorder" Property="BorderBrush" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PrimaryButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="TuneVariant" Width="18" Height="18" Margin="0,0,8,0" Foreground="#374151"/>
                <TextBlock Text="{DynamicResource VisualizerDialogHeader}" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1">
            <Border Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="205"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource VzLabelPreset}" Margin="0,0,8,6"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CboPreset" Margin="0,0,0,6"
                              SelectionChanged="CboPreset_SelectionChanged"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource VzLabelType}" Margin="0,0,8,6"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="CboType" Margin="0,0,0,6"
                              SelectionChanged="CboType_SelectionChanged">
                        <ComboBoxItem Content="showfreqs"/>
                        <ComboBoxItem Content="showwaves"/>
                    </ComboBox>

                    <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource VzLabelMode}" Margin="0,0,8,6"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CboMode" Margin="0,0,0,6"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource VzLabelLineThickness}" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtLineThickness" Margin="0,0,0,6"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="{DynamicResource VzLabelAlpha}" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtAlpha" Margin="0,0,0,6"/>

                    <Label Grid.Row="5" Grid.Column="0" Content="{DynamicResource VzLabelRate}" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtRate" Margin="0,0,0,6"/>

                    <Label Grid.Row="6" Grid.Column="0" Content="{DynamicResource VzLabelVolume}" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="TxtVolumeDb" Margin="0,0,0,6"/>

                    <Label Grid.Row="7" Grid.Column="0" Content="{DynamicResource VzLabelAScale}" Margin="0,0,8,6"/>
                    <ComboBox Grid.Row="7" Grid.Column="1" x:Name="CboAScale" Margin="0,0,0,6">
                        <ComboBoxItem Content="lin"/>
                        <ComboBoxItem Content="sqrt"/>
                        <ComboBoxItem Content="cbrt"/>
                        <ComboBoxItem Content="log"/>
                    </ComboBox>

                    <Label Grid.Row="8" Grid.Column="0" Content="{DynamicResource VzLabelWinSize}" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="8" Grid.Column="1" x:Name="TxtWinSize" Margin="0,0,0,6"/>

                    <Label Grid.Row="9" Grid.Column="0" Content="{DynamicResource VzLabelFScale}" Margin="0,0,8,0"/>
                    <ComboBox Grid.Row="9" Grid.Column="1" x:Name="CboFScale">
                        <ComboBoxItem Content="lin"/>
                        <ComboBoxItem Content="log"/>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="205"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0" Grid.ColumnSpan="2" x:Name="ChkUseColorKey"
                              Content="{DynamicResource VzLabelColorKey}"
                              Margin="0,0,0,8"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource VzLabelKeySimilarity}" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtColorKeySimilarity" Margin="0,0,0,6"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource VzLabelKeyBlend}" Margin="0,0,8,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtColorKeyBlend"/>
                </Grid>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Margin="0,0,8,0" Click="BtnCancel_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,6,0"/>
                    <TextBlock Text="{DynamicResource ButtonCancel}"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource PrimaryButton}" IsDefault="True" Click="BtnOk_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="16" Height="16" Margin="0,0,6,0"/>
                    <TextBlock Text="{DynamicResource ButtonApply}"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
