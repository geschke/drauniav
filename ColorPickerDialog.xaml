<Window x:Class="Drauniav.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cp="clr-namespace:ColorPicker;assembly=ColorPicker"
        Title="{DynamicResource ColorPickerTitle}" Width="310" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Closing="Dialog_Closing">

    <StackPanel Margin="12">

        <Button x:Name="BtnEyedropper" Content="{DynamicResource ColorPickerEyedropper}"
                HorizontalAlignment="Left" Height="26" Padding="8,0"
                Margin="0,0,0,10" Click="BtnEyedropper_Click"/>

        <cp:StandardColorPicker x:Name="Picker" ShowAlpha="False"
                                Width="286" HorizontalAlignment="Left"/>

        <Rectangle Height="22" Margin="0,10,0,0" RadiusX="2" RadiusY="2">
            <Rectangle.Fill>
                <SolidColorBrush Color="{Binding ElementName=Picker, Path=SelectedColor}"/>
            </Rectangle.Fill>
        </Rectangle>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{DynamicResource ButtonCancel}" Width="90" Height="26"
                    Margin="0,0,8,0" Click="BtnAbbrechen_Click"/>
            <Button Content="{DynamicResource ButtonApply}" Width="90" Height="26"
                    IsDefault="True" Click="BtnUebernehmen_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
