<Window x:Class="AudioVisualizer.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cp="clr-namespace:ColorPicker;assembly=ColorPicker"
        Title="Farbe wählen" Width="310" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Closing="Dialog_Closing">

    <StackPanel Margin="12">

        <!-- Eyedropper: sample a pixel directly from the background image -->
        <Button x:Name="BtnEyedropper" Content="Aus Bild übernehmen"
                HorizontalAlignment="Left" Height="26" Padding="8,0"
                Margin="0,0,0,10" Click="BtnEyedropper_Click"/>

        <!-- Full color picker (hue/sat square, sliders, hex field) -->
        <cp:StandardColorPicker x:Name="Picker" ShowAlpha="False"
                                Width="286" HorizontalAlignment="Left"/>

        <!-- Live preview of the selected color -->
        <Rectangle Height="22" Margin="0,10,0,0" RadiusX="2" RadiusY="2">
            <Rectangle.Fill>
                <SolidColorBrush Color="{Binding ElementName=Picker, Path=SelectedColor}"/>
            </Rectangle.Fill>
        </Rectangle>

        <!-- OK / Cancel -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Abbrechen" Width="90" Height="26"
                    Margin="0,0,8,0" Click="BtnAbbrechen_Click"/>
            <Button Content="Übernehmen" Width="90" Height="26"
                    IsDefault="True" Click="BtnUebernehmen_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
